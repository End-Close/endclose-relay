{
  "name": "endclose-relay",
  "version": "0.1.0",
  "description": "Self-hosted webhook relay appliance: receives payment-processor webhooks, persists, masks, and forwards them to End Close via the public API",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:all": "mprocs",
    "dev:ui": "vite",
    "build": "tsc && mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/ && vite build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p ui"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "better-sqlite3": "^11.10.0",
    "fastify": "^5.3.2",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "mprocs": "^0.9.6",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^7.3.6",
    "vitest": "^3.0.9"
  }
}
