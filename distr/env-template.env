# endclose-relay deployment environment (Distr).
#
# DEFAULT: the five secret values come from your Distr Customer Portal's Secrets
# (write-only after creation; never visible to End Close). Enter them there once and
# leave the references below untouched.
#
# STRICT MODE (policy forbids secrets on third-party infrastructure): blank out the
# five secret references below, create /etc/endclose-relay/relay.env on the host
# (mode 600) containing these five variables, and set
# RELAY_SECRETS_FILE=/host-config/relay.env
#
# See relay.example.yaml for what each secret does.

ENDCLOSE_API_KEY={{ .Secrets.endclose_api_key }}
PAYABLI_WEBHOOK_SECRET={{ .Secrets.payabli_webhook_secret }}
RELAY_DATA_KEY={{ .Secrets.relay_data_key }}
MASKING_HMAC_KEY={{ .Secrets.masking_hmac_key }}
ADMIN_BASIC_AUTH={{ .Secrets.admin_basic_auth }}

# Strict mode only — otherwise leave empty:
RELAY_SECRETS_FILE=
